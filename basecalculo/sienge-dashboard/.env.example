# Backend (FastAPI) usa estas variáveis para chamar a API do Sienge.
SIENGE_INSTANCE=SEU_CLIENTE
SIENGE_BASE_URL=https://api.sienge.com.br/SEU_CLIENTE
SIENGE_ACCESS_NAME=seu-access-name
SIENGE_TOKEN=seu-token
SIENGE_SYNC_INTERVAL_MINUTES=20

# Frontend (Vite) não deve receber token do Sienge no bundle.
# Se precisar mudar o alvo do proxy /api durante o dev, use:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
